    "title": "How an HTTP Request Actually Works",
    "topic_source": "seed",
    "caption": "Every HTTP request starts with a DNS lookup, then a TCP handshake, then the actual GET request to the server. Follow @byteflow for daily systems & AI breakdowns.",
    "hashtags": ["#systemdesign", "#http", "#webdev", "#networking", "#softwareengineering"],
    "scenes": [
      {
        "layout": "nodes-flow",
        "heading": "DNS lookup then request",
        "nodes": [
          {"id": "client", "icon": "🖥️", "label": "CLIENT"},
          {"id": "dns", "icon": "🌐", "label": "DNS"},
          {"id": "server", "icon": "🗄️", "label": "SERVER"}
        ],
        "steps": [
          {"from": "client", "to": "dns", "packet": "QUERY", "color": "accent", "status": "resolve domain to ip"},
          {"from": "dns", "to": "client", "packet": "IP", "color": "good", "status": "ip address returned"},
          {"from": "client", "to": "server", "packet": "GET", "color": "accent", "status": "request sent over tcp"},
          {"from": "server", "to": "client", "packet": "200", "color": "good", "status": "html response returned"}
        ]
      }
    ]
  },
