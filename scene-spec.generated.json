{
  "title": "SERVICE MESH: SIDECAR PROXY PATTERN",
  "scenes": [
    {
      "layout": "nodes-flow",
      "nodes": [
        {
          "id": "client_app",
          "label": "CLIENT APP",
          "icon": "📱"
        },
        {
          "id": "microservice",
          "label": "MICROSERVICE",
          "icon": "⚙️"
        }
      ],
      "steps": [
        {
          "from": "client_app",
          "to": "microservice",
          "packet": "REQ",
          "status": "request sent",
          "color": "accent"
        },
        {
          "from": "microservice",
          "to": "client_app",
          "packet": "200",
          "status": "response received",
          "color": "good"
        }
      ],
      "heading": "DIRECT COMMUNICATION"
    },
    {
      "layout": "nodes-flow",
      "nodes": [
        {
          "id": "client_app_mesh",
          "label": "CLIENT APP",
          "icon": "📱"
        },
        {
          "id": "sidecar_proxy",
          "label": "SIDECAR",
          "icon": "🛡️"
        },
        {
          "id": "microservice_mesh",
          "label": "MICROSERVICE",
          "icon": "⚙️"
        }
      ],
      "steps": [
        {
          "from": "client_app_mesh",
          "to": "sidecar_proxy",
          "packet": "REQ",
          "status": "request to mesh",
          "color": "accent"
        },
        {
          "from": "sidecar_proxy",
          "to": "microservice_mesh",
          "packet": "REQ",
          "status": "proxy to service",
          "color": "accent"
        },
        {
          "from": "microservice_mesh",
          "to": "sidecar_proxy",
          "packet": "200",
          "status": "service to proxy",
          "color": "good"
        },
        {
          "from": "sidecar_proxy",
          "to": "client_app_mesh",
          "packet": "200",
          "status": "mesh to client (metrics)",
          "color": "good"
        }
      ],
      "heading": "WITH SERVICE MESH"
    }
  ],
  "caption": "A service mesh adds a network proxy (sidecar) to each microservice. This decouples reliability, security, and observability features from application code, managing them at the infrastructure layer. It centralizes control over traffic management, retries, and more, making distributed systems easier to build and operate. Follow @byteflowlabs for daily systems & AI breakdowns.",
